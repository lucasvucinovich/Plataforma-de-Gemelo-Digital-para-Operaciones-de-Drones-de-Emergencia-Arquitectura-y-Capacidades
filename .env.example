# Klout-semifinal – Environment variables
# Copy to .env.local and adjust. No .env is required for local dev; defaults apply.

# -----------------------------------------------------------------------------
# Scenario run persistence (optional)
# -----------------------------------------------------------------------------
# SCENARIO_PERSISTENCE_ENABLED=true
# SCENARIO_PERSISTENCE_DIR=./data/scenarios/runs

# -----------------------------------------------------------------------------
# Jarvis / AI (provider-agnostic; choose one or wire via JARVIS_PROVIDER)
# -----------------------------------------------------------------------------
# Provider selection: set JARVIS_PROVIDER and the corresponding API key.
# Supported: openai, mistral, gemini, anthropic
# JARVIS_PROVIDER=mistral
# JARVIS_MODEL=mistral-small-latest
# JARVIS_TIMEOUT_MS=10000
#
# OpenAI (JARVIS_PROVIDER=openai)
# JARVIS_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
#
# Mistral (JARVIS_PROVIDER=mistral)
# JARVIS_MODEL=mistral-small-latest
# MISTRAL_API_KEY=...
#
# Google Gemini (JARVIS_PROVIDER=gemini)
# JARVIS_MODEL=gemini-1.5-flash
# GEMINI_API_KEY=...
#
# Anthropic (JARVIS_PROVIDER=anthropic)
# JARVIS_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=...
