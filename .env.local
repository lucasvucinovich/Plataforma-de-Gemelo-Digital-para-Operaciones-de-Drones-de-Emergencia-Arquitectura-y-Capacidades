# Klout-semifinal – Local environment (override defaults)
# Copy from .env.example and adjust. This file is gitignored.

# -----------------------------------------------------------------------------
# Jarvis / AI – Mistral provider
# -----------------------------------------------------------------------------
JARVIS_PROVIDER=mistral
JARVIS_MODEL=mistral-small-latest
JARVIS_TIMEOUT_MS=10000

# Mistral API (get key at https://console.mistral.ai/)
MISTRAL_API_KEY=afqOlkWuJYmCQLjWSZt9QMAM0jKH6ZDA

# -----------------------------------------------------------------------------
# Scenario run persistence (optional, uncomment to enable)
